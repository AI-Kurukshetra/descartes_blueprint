# TradeGuard Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# SUPABASE (Required)
# ===========================================
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key - SERVER SIDE ONLY (never expose to client)
# Used for admin operations like seeding data
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# OPENAI (Required for HS Classification)
# ===========================================
# Get this from https://platform.openai.com/api-keys
# SERVER SIDE ONLY - do not prefix with NEXT_PUBLIC_
OPENAI_API_KEY=sk-your-openai-api-key

# ===========================================
# OPTIONAL SETTINGS
# ===========================================
# Node environment
NODE_ENV=development

# ===========================================
# SECURITY NOTES
# ===========================================
# - Never commit .env.local to version control
# - Only NEXT_PUBLIC_ prefixed variables are exposed to the browser
# - Keep SUPABASE_SERVICE_ROLE_KEY and OPENAI_API_KEY server-side only
# - Rotate keys if they are ever exposed
